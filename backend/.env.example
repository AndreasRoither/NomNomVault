# Required for local backend development outside Docker.
DATABASE_URL=postgres://nomnomvault:nomnomvault@127.0.0.1:5432/nomnomvault?sslmode=disable

# Optional development overrides.
# APP_ENV=development
# AUTH_JWT_SECRET=dev-jwt-secret-not-for-development
# AUTH_CSRF_SECRET=dev-csrf-secret-not-for-development
# COOKIE_SECURE=false
# TRUSTED_PROXIES=
# MAX_UPLOAD_BYTES=10485760
# ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp
# ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# AUTH_LOGIN_RATE_LIMIT_PER_MINUTE=5
# AUTH_REFRESH_RATE_LIMIT_PER_MINUTE=30
